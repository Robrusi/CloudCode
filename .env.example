
# Deployment used by `npx convex dev`
CONVEX_DEPLOYMENT=

NEXT_PUBLIC_CONVEX_URL=

NEXT_PUBLIC_CONVEX_SITE_URL=


DAYTONA_API_KEY=
DAYTONA_TARGET=
DAYTONA_DEFAULT_SNAPSHOT=cloudcode-batteries-included
# Keep Codex upgrades deliberate because app-server schemas are version-specific.
CLOUDCODE_CODEX_CLI_VERSION=0.136.0

TRIGGER_PROJECT_REF=
# TRIGGER_SECRET_KEY and TRIGGER_WORKER_SECRET must ALSO be set in the Convex
# deployment environment (npx convex env set ...): the factory MCP dispatch
# action queues Trigger.dev tasks from Convex with the same secret key.
TRIGGER_SECRET_KEY=
TRIGGER_WORKER_SECRET=

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

AUTUMN_SECRET_KEY=
AUTUMN_FREE_INCLUDED_MICRO_USD=
AUTUMN_HOBBY_INCLUDED_MICRO_USD=
AUTUMN_PLUS_INCLUDED_MICRO_USD=
NEXT_PUBLIC_AUTUMN_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
CLOUDCODE_SECRET_ENCRYPTION_KEY=


CLERK_FRONTEND_API_URL=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

CLERK_JWT_ISSUER_DOMAIN=

GITHUB_APP_ID=
GITHUB_APP_SLUG=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY_BASE64=
# Webhook secret configured on the GitHub App (Settings -> Webhook). Enables
# /api/github/webhook, which triggers PR reviews. Subscribe the app to
# "Pull requests" and "Issue comment" events (the latter powers @<app-slug>
# mention-triggered reviews) and point its webhook URL at
# <app>/api/github/webhook.
GITHUB_APP_WEBHOOK_SECRET=

# --- Chat integrations (Slack + Linear sessions and automation triggers) ---
# Redis TCP endpoint (rediss://default:<password>@<host>:6379) for the Chat
# SDK state store: thread subscriptions, event dedup, and the Linear OAuth
# installation (tokens encrypted with LINEAR_ENCRYPTION_KEY). The Upstash
# REST credentials above cannot serve the Redis protocol; copy the TCP
# endpoint from the same Upstash database. Also set these in the Trigger.dev
# environment — outbound replies post from the worker.
INTEGRATIONS_REDIS_URL=

# Slack app: create once at https://api.slack.com/apps with bot scopes
# app_mentions:read, chat:write, channels:history, channels:read,
# groups:history, groups:read, im:history, im:read, mpim:history, mpim:read,
# reactions:read, reactions:write, users:read, users:read.email; event
# subscriptions app_mention, message.channels, message.groups, message.im,
# message.mpim, reaction_added; request URL <app>/api/slack/webhook; OAuth
# redirect URL <app>/api/slack/oauth/callback.
#
# OAuth mode (recommended): set the client ID/secret from Basic Information
# and "Connect Slack" in settings runs the workspace install in the browser.
# The per-workspace bot token is stored in the Redis state store, encrypted
# with SLACK_ENCRYPTION_KEY (openssl rand -base64 32).
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_ENCRYPTION_KEY=
# Token mode (alternative): install the app manually in Slack's dashboard and
# pin its bot token here. Takes precedence over OAuth mode when set.
SLACK_BOT_TOKEN=
# Required in both modes (Basic Information -> App Credentials).
SLACK_SIGNING_SECRET=

# Linear OAuth app (agent sessions): create at Linear Settings -> API ->
# Applications with redirect <app>/api/linear/oauth/callback and a webhook at
# <app>/api/linear/webhook subscribed to "Agent session events", "Issues",
# and "Comments". LINEAR_ENCRYPTION_KEY is a base64 32-byte key
# (openssl rand -base64 32) encrypting stored workspace tokens.
LINEAR_CLIENT_ID=
LINEAR_CLIENT_SECRET=
LINEAR_WEBHOOK_SECRET=
LINEAR_ENCRYPTION_KEY=
