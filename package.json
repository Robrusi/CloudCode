    "test:linear-integration": "tsx scripts/test-linear-integration.ts",
    "test:reviews": "tsx scripts/test-reviews.ts",
    "test:billing": "tsx scripts/test-billing-autumn-client.ts",
    "test:integration-mcp": "tsx scripts/test-integration-mcp.ts",
    "test:integration-delivery": "tsx scripts/test-integration-delivery.ts",
    "test:codex-app-server": "tsx scripts/test-codex-app-server.ts && tsx scripts/test-codex-app-server-daemon.ts && pnpm check:codex-app-server-protocol",
    "typecheck": "tsc --noEmit"
